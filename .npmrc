engine-strict=true
package-lock=true

# Supply-chain cooldown (issue #830): reject freshly-published versions so a
# compromised release has to survive a quarantine window before it is
# installable. `minimum-release-age` requires npm >= 11.6.1; the current
# toolchain ships npm 10.x, where this key is silently ignored. Uncomment once
# CI/dev standardise on npm >= 11.6 (e.g. via a newer setup-node) so it is
# actually enforced rather than giving false assurance.
# minimum-release-age=1440
