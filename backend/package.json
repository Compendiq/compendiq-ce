    "@fastify/sensible": "^6.0.3",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^5.2.1",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/auto-instrumentations-node": "^0.71.0",
