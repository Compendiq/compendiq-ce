# ============================================
# Compendiq - Environment Configuration
# ============================================
# Copy this file to .env and fill in real values.
# NEVER commit .env to git.

# === Application ===

# --- Docker image version (set by install.sh; pin to a specific release e.g. 1.0.0) ---
# COMPENDIQ_VERSION=latest

# --- Required Secrets (MUST change in production) ---
JWT_SECRET=change-me-to-a-random-32-char-string-min
PAT_ENCRYPTION_KEY=change-me-to-a-random-32-char-string-min

# --- PostgreSQL ---
POSTGRES_URL=postgresql://kb_user:changeme-postgres@localhost:5432/kb_creator

# PG_POOL_MAX=20                       # PostgreSQL connection pool max (default: 20)
# PG_STATEMENT_TIMEOUT=30000           # Global query timeout in ms (default: none)

# --- PostgreSQL (Test - port 5433) ---
POSTGRES_TEST_URL=postgresql://kb_user:changeme-postgres@localhost:5433/kb_creator_test

# --- Redis ---
REDIS_URL=redis://:changeme-redis@localhost:6379

# --- Server ---
NODE_ENV=development
BACKEND_PORT=3051
# FRONTEND_URL=http://localhost:5273    # Used for CORS origin (default: http://localhost:5273)
# LOG_LEVEL=info                        # Pino log level: 'fatal','error','warn','info','debug','trace' (default: info)

# --- Session ---
# ACCESS_TOKEN_EXPIRY=1h      # JWT access token lifetime (default: 1h). Accepts jose duration format: '30m', '1h', '2h', etc.
# TOKEN_CLEANUP_INTERVAL_HOURS=24  # How often to run expired refresh token cleanup (default: 24h)

# --- LLM Provider (default: ollama) ---
# LLM_PROVIDER=ollama          # "ollama" or "openai" (server-wide default, can be overridden per-user)

# --- Ollama / LLM (shared server) ---
OLLAMA_BASE_URL=http://localhost:11434
EMBEDDING_MODEL=bge-m3
# EMBEDDING_DIMENSIONS=1024            # Vector dimensions — must match the embedding model output
# FTS_LANGUAGE=simple                   # Full-text search language: simple, english, german, french, etc.
# BGE-M3 via Ollama (1024 dims). Run: ollama pull bge-m3
# LLM_BEARER_TOKEN=           # Optional: Bearer token for authenticated Ollama/LLM proxies
# LLM_AUTH_TYPE=bearer         # Auth type for LLM connections: 'bearer' (default) or 'none'
# LLM_VERIFY_SSL=true          # Set to 'false' to disable TLS certificate verification for LLM connections
# LLM_STREAM_TIMEOUT_MS=300000 # Streaming request timeout in ms (default: 300000 = 5 min). Increase for very large articles.
# LLM_CACHE_TTL=3600           # Redis TTL in seconds for LLM response cache (default: 3600 = 1 hour)

# --- Default LLM Model (fallback for background workers) ---
# DEFAULT_LLM_MODEL=                 # Fallback model for quality and summary workers when their specific model env var is not set

# --- Background Auto-Summarizer ---
# SUMMARY_CHECK_INTERVAL_MINUTES=60  # How often the worker scans for pages needing summaries (default: 60)
# SUMMARY_BATCH_SIZE=5               # Max pages to summarize per worker cycle (default: 5)
# SUMMARY_MODEL=                     # LLM model for summaries (default: DEFAULT_LLM_MODEL, then empty = disabled)

# --- OpenAI-compatible API (alternative to Ollama) ---
# Works with: OpenAI, Azure OpenAI, LM Studio, vLLM, llama.cpp server, LocalAI, etc.
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_API_KEY=              # API key (required when using openai provider)

# --- Quality Analysis Worker ---
# QUALITY_CHECK_INTERVAL_MINUTES=60  # How often the quality worker runs (default: 60 min)
# QUALITY_BATCH_SIZE=5               # Pages analyzed per batch (default: 5)
# QUALITY_MODEL=qwen3:4b             # LLM model for quality analysis (default: DEFAULT_LLM_MODEL, then qwen3:4b)

# --- Sync Scheduler ---
# SYNC_INTERVAL_MIN=15               # How often the background sync scheduler polls for due syncs, in minutes (default: 15)

# --- MCP Documentation Sidecar (air-gapped LLM doc access) ---
# MCP_DOCS_URL=http://mcp-docs:3100/mcp  # URL of the MCP docs sidecar (default in Docker)
# MCP_LOG_LEVEL=info                       # Log level for the sidecar container
# MCP_CACHE_TTL=3600                       # Default cache TTL in seconds
# All other MCP Docs settings (enabled, domain allow/blocklist) are managed via Admin Settings UI.

# --- RAG / Vector Search ---
# RAG_EF_SEARCH=100                  # HNSW ef_search parameter for pgvector similarity queries (default: 100)

# --- Data Retention ---
# RETENTION_AUDIT_LOG_DAYS=365       # Keep audit_log rows for N days (default: 365)
# RETENTION_SEARCH_ANALYTICS_DAYS=90 # Keep search_analytics rows for N days (default: 90)
# RETENTION_ERROR_LOG_DAYS=30        # Keep error_log rows for N days (default: 30)
# RETENTION_VERSIONS_MAX=50          # Keep last N page_versions per page (default: 50)

# --- Enterprise License ---
# COMPENDIQ_LICENSE_KEY=              # Enterprise license key (format: ATM-{tier}-{seats}-{expiryYYYYMMDD}.{signature})

# --- OIDC / SSO ---
# OIDC/SSO is available in the Enterprise Edition only.

# --- Confluence (optional, can be set per-user in UI) ---
# CONFLUENCE_VERIFY_SSL=true

# --- Attachments (local cache for draw.io and image attachments synced from Confluence) ---
# ATTACHMENTS_DIR=data/attachments   # Relative to backend working dir (default). Set to an absolute path in production.

# --- Draw.io Editor ---
# The draw.io embed URL is configurable at runtime via Admin Settings in the UI.
# No env var is required — the default (https://embed.diagrams.net) is used automatically.
# Override in Admin Settings if embed.diagrams.net is blocked by your firewall.
# NOTE: If using a custom draw.io URL, also update the frame-src CSP in frontend/nginx-security-headers.conf.

# --- Custom CA Bundle (for self-signed certificates) ---
# NODE_EXTRA_CA_CERTS=/path/to/ca-bundle.pem  # PEM CA bundle file path (also used by Node.js natively)

# === Encryption Key Rotation ===
# To rotate the PAT encryption key without downtime, provide multiple versioned keys.
# New encryptions always use the highest-version key; decryption tries all keys so
# old PATs remain readable during the rotation window.
#
# Option A: JSON array of { version, key } objects
# PAT_ENCRYPTION_KEYS='[{"version":2,"key":"new-key-at-least-32-characters!!!!!"},{"version":1,"key":"old-key-at-least-32-characters!!!!!"}]'
#
# Option B: Numbered env vars (V1 through V10)
# PAT_ENCRYPTION_KEY_V1=old-key-at-least-32-characters!!!!!
# PAT_ENCRYPTION_KEY_V2=new-key-at-least-32-characters!!!!!
#
# The plain PAT_ENCRYPTION_KEY above is treated as version 0 (legacy fallback).
# Once all PATs have been re-encrypted with the new key, remove the old key.

# === OpenTelemetry (optional) ===
# OTEL_ENABLED=false                          # Set to 'true' to enable OpenTelemetry tracing (default: false)
# OTEL_SERVICE_NAME=compendiq-backend         # Service name reported to the OTLP collector (default: compendiq-backend)
# OTEL_EXPORTER_OTLP_ENDPOINT=               # OTLP collector endpoint, e.g. http://localhost:4318

# --- SearXNG (optional) ---
# SEARXNG_LIMITER=false              # Enable rate limiter (true for public-facing)
# SEARXNG_IMAGE_PROXY=false          # Enable image proxying
# SEARXNG_SECRET_KEY=                # Override auto-generated secret key

# === Docker Compose Only ===
# These variables are used by docker-compose.yml and are NOT read by the application directly.
# POSTGRES_USER=kb_user                       # PostgreSQL superuser name (used in docker-compose)
# POSTGRES_PASSWORD=changeme-postgres         # PostgreSQL superuser password (used in docker-compose)
# POSTGRES_DB=kb_creator                      # PostgreSQL database name (used in docker-compose)
# REDIS_PASSWORD=changeme-redis               # Redis AUTH password (used in docker-compose)
# FRONTEND_PORT=5273                          # Host port mapped to the frontend container
# HOST_CA_BUNDLE_PATH=/etc/pki/ca-trust/extracted/pem/tls-ca-bundle.pem    # Host path to CA bundle (bind-mounted into container)
# CONTAINER_CA_BUNDLE_PATH=/etc/ssl/certs/ca-certificates.crt              # Container path for the CA bundle
