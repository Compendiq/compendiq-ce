# ============================================
# AI KB Creator - Environment Configuration
# ============================================
# Copy this file to .env and fill in real values.
# NEVER commit .env to git.

# --- Required Secrets (MUST change in production) ---
JWT_SECRET=change-me-to-a-random-32-char-string-min
PAT_ENCRYPTION_KEY=change-me-to-a-random-32-char-string-min

# --- PostgreSQL ---
POSTGRES_USER=kb_user
POSTGRES_PASSWORD=changeme-postgres
POSTGRES_DB=kb_creator
POSTGRES_URL=postgresql://kb_user:changeme-postgres@localhost:5432/kb_creator

# --- PostgreSQL (Test - port 5433) ---
POSTGRES_TEST_URL=postgresql://kb_user:changeme-postgres@localhost:5433/kb_creator_test

# --- Redis ---
REDIS_PASSWORD=changeme-redis
REDIS_URL=redis://:changeme-redis@localhost:6379

# --- Ollama / LLM (shared server) ---
OLLAMA_BASE_URL=http://localhost:11434
EMBEDDING_MODEL=nomic-embed-text
# LLM_BEARER_TOKEN=           # Optional: Bearer token for authenticated Ollama/LLM proxies
# LLM_AUTH_TYPE=bearer         # Auth type for LLM connections: 'bearer' (default) or 'none'
# LLM_VERIFY_SSL=true          # Set to 'false' to disable TLS certificate verification for LLM connections

# --- Server ---
NODE_ENV=development
BACKEND_PORT=3051
FRONTEND_PORT=5273

# --- Confluence (optional, can be set per-user in UI) ---
# CONFLUENCE_VERIFY_SSL=true

# --- Custom CA Bundle (for self-signed certificates) ---
# HOST_CA_BUNDLE_PATH=/etc/pki/ca-trust/extracted/pem/tls-ca-bundle.pem
# CONTAINER_CA_BUNDLE_PATH=/etc/ssl/certs/ca-certificates.crt
